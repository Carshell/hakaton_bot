BOT_TOKEN=your_telegram_bot_token_here
DATABASE_PATH=data/bot.db

# URLs
LANDING_URL=https://example.com/hackathon
HACKATHON_SITE_URL=https://example.com/hackathon
PRIVACY_POLICY_URL=https://example.com/privacy

# Admin (comma-separated Telegram user IDs)
ADMIN_USER_IDS=123456789
# Chat ID where user feedback is forwarded (group or admin DM)
ADMIN_CHAT_ID=-1001234567890

# Google Sheets (optional — bot works without it)
GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_CREDENTIALS_PATH=credentials/google-service-account.json
